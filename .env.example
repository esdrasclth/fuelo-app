# PostgreSQL.
# Dev local (Docker): ambas apuntan al mismo Postgres local.
# Producción (Neon):
#   DATABASE_URL -> connection string CON pooler (el host incluye "-pooler"), usada por la app.
#   DIRECT_URL   -> connection string directa (sin "-pooler"), usada por las migraciones.
DATABASE_URL="postgresql://fuelo:fuelo@localhost:5434/fuelo?schema=public"
DIRECT_URL="postgresql://fuelo:fuelo@localhost:5434/fuelo?schema=public"

# Auth.js (NextAuth v5). Genera uno con: npx auth secret  (o openssl rand -base64 32)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL base de la app
AUTH_URL="http://localhost:3000"
