generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FuelType {
  MAGNA
  PREMIUM
  DIESEL
}

enum ReminderType {
  SERVICE
  REFUEL
  VERIFICATION
  INSURANCE
  OTHER
}

enum DistanceUnit {
  KM
  MI
}

enum VolumeUnit {
  L
  GAL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  currency         String  @default("HNL")
  defaultVehicleId String?
  defaultStationId String?
  createdAt    DateTime   @default(now())

  vehicles  Vehicle[]
  fuelLogs  FuelLog[]
  stations  Station[]
  reminders Reminder[]
  trips     Trip[]
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  name         String
  make         String?
  model        String?
  year         Int?
  plate        String?
  fuelType     FuelType @default(MAGNA)
  tankCapacity Float?
  distanceUnit DistanceUnit @default(KM)
  volumeUnit   VolumeUnit   @default(L)
  createdAt    DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelLogs  FuelLog[]
  reminders Reminder[]
  trips     Trip[]

  @@index([userId])
}

model Station {
  id        String   @id @default(cuid())
  userId    String
  brand     String
  branch    String?
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelLogs FuelLog[]

  @@index([userId])
}

model FuelLog {
  id            String   @id @default(uuid())
  userId        String
  vehicleId     String
  date          DateTime @default(now())
  odometer      Float
  liters        Float
  pricePerLiter Float
  totalCost     Float
  fuelType      FuelType @default(MAGNA)
  stationId     String?
  isFullTank    Boolean  @default(true)
  missedPrevious Boolean @default(false)
  latitude      Float?
  longitude     Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  station Station? @relation(fields: [stationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([vehicleId, date])
}

model Reminder {
  id          String       @id @default(cuid())
  userId      String
  vehicleId   String?
  type        ReminderType @default(SERVICE)
  title       String
  dueDate     DateTime?
  dueOdometer Float?
  recurring   Boolean      @default(false)
  intervalDays Int?
  completed   Boolean      @default(false)
  notes       String?
  createdAt   DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Trip {
  id              String   @id @default(cuid())
  userId          String
  vehicleId       String?
  name            String
  originLabel     String
  originLat       Float
  originLng       Float
  destLabel       String
  destLat         Float
  destLng         Float
  distanceKm      Float
  durationMin     Float?
  estimatedLiters Float?
  estimatedCost   Float?
  roundTrip       Boolean  @default(false)
  createdAt       DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([userId])
}
